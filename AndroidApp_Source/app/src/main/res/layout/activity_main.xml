<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0a0e1a">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="IndoorNav Scanner"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#f1f5f9"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Server IP Address"
        android:textColor="#94a3b8"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/ipAddressInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#111827"
        android:textColor="#ffffff"
        android:hint="192.168.x.x"
        android:textColorHint="#64748b"
        android:padding="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Destination Room (Optional)"
        android:textColor="#94a3b8"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/destinationInput"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#111827"
        android:textColor="#ffffff"
        android:hint="e.g. B-412_Right"
        android:textColorHint="#64748b"
        android:padding="12dp"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnLocalizeOnly"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="📍 Localize Only"
            android:backgroundTint="#8b5cf6"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnNavigate"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="🧭 Navigate"
            android:backgroundTint="#3b82f6"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.4"
        android:background="#1e293b"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#34d399"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:text="Results will appear here..."/>
    </ScrollView>

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.6"
        android:background="#0f172a"/>

</LinearLayout>
